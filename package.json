{
  "name": "cognitive-dual-engine",
  "version": "1.0.0",
  "description": "OpenClaw plugin: System 1/System 2 cognitive routing with FLARE planning engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonyhu2006/cognitive-dual-engine.git"
  },
  "homepage": "https://github.com/tonyhu2006/cognitive-dual-engine#readme",
  "bugs": {
    "url": "https://github.com/tonyhu2006/cognitive-dual-engine/issues"
  },
  "author": "tonyhu2006",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "cognitive-routing",
    "dual-process",
    "flare",
    "planning",
    "ai-agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2025.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  }
}